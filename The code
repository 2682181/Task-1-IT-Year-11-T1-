	static void GuessCard()
	{
		Random rng = new Random();
		int CardNum = rng.Next(1, 14);
		string[] suits =
		{
			"Hearts",
			"Diamonds",
			"Clubs",
			"Spades"
		};
		string suit = suits[rng.Next(0, 4)];
		string card;
		if (CardNum == 1)
			card = "Ace";
		else if (CardNum == 11)
			card = "Jack";
		else if (CardNum == 12)
			card = "Queen";
		else if (CardNum == 13)
			card = "King";
		else
			card = CardNum.ToString();
		Console.Write("Guess a card e.g(3 Diamonds): ");
		Console.ReadLine();
		Console.WriteLine($"\nThe card was {card} of {suit}.");
	}

	static void PlayBYE()
	{
		Console.WriteLine("Thank You For Playing, See You Next Time :)");
	}
}
