					running = false;
					break;
				default:
					Console.WriteLine("Invalid choice. Try again.");
					break;
			}
		}
	}

	static void PlayCoinGame()
	{
		string result;
		Random rng = new Random();
		Console.Write("Guess the coin flip (Heads/Tails): ");
		string guess = Console.ReadLine().ToLower();
		int side = rng.Next(0, 2);
		if (side == 0)
		{
			result = "heads";
		}
		else
		{
			result = "tails";
		}

		if (guess != "tails" && guess != "heads")
		{
			Console.WriteLine("Please Write only 'heads' or 'tails'");
			PlayCoinGame();
		}

		if (result == guess)
		{
			Console.WriteLine($"\nNice Guess, the coin landed on {result}");
		}
		else if (result != guess)
		{
			Console.WriteLine($"\nBetter Luck next time, the coin landed on {result}");
		}
	}

	static void PlayDie6Game()
	{
		Random rng = new Random();
		Console.Write("Guess the roll of a 6-sided die (1-6): ");
		int guess;
		if (!int.TryParse(Console.ReadLine(), out guess) || guess < 1 || guess > 6)
		{
			Console.WriteLine("Invalid input.");
			return;
		}

		int roll = rng.Next(1, 7);
		Console.WriteLine($"\nThe die rolled {roll}.");
	}

	static void PlayDie20Game()
	{
		Random rng = new Random();
		Console.Write("Guess the roll of a 20-sided die (1-20): ");
		int guess;
		if (!int.TryParse(Console.ReadLine(), out guess) || guess < 1 || guess > 20)
		{
			Console.WriteLine("Invalid input.");
			return;
		}

		int roll = rng.Next(1, 21);
		Console.WriteLine($"\nThe die rolled {roll}.");
	}

