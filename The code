using System;

public class Program
{
	public static void Main()
	{
		bool running = true;
		while (running)
		{
			Console.WriteLine("       ----- Main Menu ----- ");
			Console.WriteLine("\n What Game Would You Like To Play? \n");
			Console.WriteLine("Press 1 To Play Rock, Paper, Scissors (PVC)");
			Console.WriteLine("Press 2 To Play Tic Tac Toe (PVP)");
			Console.WriteLine("Press 3 To Play Feeling Lucky?");
			Console.WriteLine("Press 4 To Leave The Game");
			string GC = Console.ReadLine();
			switch (GC)
			{
				case "1":
					PlayRPS();
					break;
				case "2":
					PlayTTT();
					break;
				case "3":
					PlayFK();
					break;
				case "4":
					PlayBYE();
					running = false;
					break;
				default:
					Console.WriteLine("Invalid selection. Please Try Again.");
					break;
			}
		}

		static void PlayRPS()
		{
			Console.WriteLine(" -----Welcome To Rock, Paper, Scissors---- ");
			Console.WriteLine("Type Rock, Paper, or Scissors To Play");
			Console.WriteLine("Press 'Q' at any time to return to Main Menu.\n");
			Random RPSRNG = new Random();
			while (true)
			{
				Console.Write("Your choice: ");
				string input = Console.ReadLine().ToLower();
				if (input == "q")
				{
					return;
				}

				if (input != "rock" && input != "paper" && input != "scissors")
				{
					Console.WriteLine("Invalid Input. Please Type either Rock, Paper Or Scissors To Play.\n");
					continue;
				}

				int ComputerNum = RPSRNG.Next(1, 4);
				string ComputerThird = "";
				switch (ComputerNum)
				{
					case 1:
						ComputerThird = "rock";
						break;
					case 2:
						ComputerThird = "paper";
						break;
					case 3:
						ComputerThird = "scissors";
						break;
				}

				Console.WriteLine($"Computer chose: {ComputerThird}");
				if (input == ComputerThird)
				{
					Console.WriteLine("It's a draw! \n");
				}
				else if ((input == "rock" && ComputerThird == "scissors") || (input == "paper" && ComputerThird == "rock") || (input == "scissors" && ComputerThird == "paper"))
				{
					Console.WriteLine("You win this round! \n");
				}
				else
				{
					Console.WriteLine("Computer wins this round! \n");
				}
			}
		}
	}

	static void PlayTTT()
	{
		char[, ] TTTboard =
		{
			{
				'1',
				'2',
				'3'
			},
			{
				'4',
				'5',
				'6'
			},
			{
				'7',
				'8',
				'9'
			}
		};
		char TTTCurrentPlayer = 'X';
		int moves = 0;
		Console.WriteLine("  -----Welcome To Tic, Tac, Toe-----  ");
		Console.WriteLine("Press 'Q' At Any Time To Return To Main Menu.\n");
		while (true)
		{
			Console.WriteLine($" {TTTboard[0, 0]} | {TTTboard[0, 1]} | {TTTboard[0, 2]} ");
			Console.WriteLine("---+---+---");
			Console.WriteLine($" {TTTboard[1, 0]} | {TTTboard[1, 1]} | {TTTboard[1, 2]} ");
			Console.WriteLine("---+---+---");
			Console.WriteLine($" {TTTboard[2, 0]} | {TTTboard[2, 1]} | {TTTboard[2, 2]} \n");
			Console.WriteLine($"Player {TTTCurrentPlayer}, choose a square (1-9):");
			string TTTinput = Console.ReadLine();
			if (TTTinput.ToLower() == "q")
				return;
			if (!int.TryParse(TTTinput, out int position) || position < 1 || position > 9)
			{
				Console.WriteLine("Invalid input. Please enter a number between 1 and 9.\n");
				continue;
			}

			int row = (position - 1) / 3;
			int col = (position - 1) % 3;
			if (TTTboard[row, col] == 'X' || TTTboard[row, col] == 'O')
			{
				Console.WriteLine("That square is already taken. Choose another.\n");
				continue;
			}

			TTTboard[row, col] = TTTCurrentPlayer;
			moves++;
			bool win = (TTTboard[0, 0] == TTTCurrentPlayer && TTTboard[0, 1] == TTTCurrentPlayer && TTTboard[0, 2] == TTTCurrentPlayer) || (TTTboard[1, 0] == TTTCurrentPlayer && TTTboard[1, 1] == TTTCurrentPlayer && TTTboard[1, 2] == TTTCurrentPlayer) || (TTTboard[2, 0] == TTTCurrentPlayer && TTTboard[2, 1] == TTTCurrentPlayer && TTTboard[2, 2] == TTTCurrentPlayer) || (TTTboard[0, 0] == TTTCurrentPlayer && TTTboard[1, 0] == TTTCurrentPlayer && TTTboard[2, 0] == TTTCurrentPlayer) || (TTTboard[0, 1] == TTTCurrentPlayer && TTTboard[1, 1] == TTTCurrentPlayer && TTTboard[2, 1] == TTTCurrentPlayer) || (TTTboard[0, 2] == TTTCurrentPlayer && TTTboard[1, 2] == TTTCurrentPlayer && TTTboard[2, 2] == TTTCurrentPlayer) || (TTTboard[0, 0] == TTTCurrentPlayer && TTTboard[1, 1] == TTTCurrentPlayer && TTTboard[2, 2] == TTTCurrentPlayer) || (TTTboard[0, 2] == TTTCurrentPlayer && TTTboard[1, 1] == TTTCurrentPlayer && TTTboard[2, 0] == TTTCurrentPlayer);
			if (win)
			{
				Console.WriteLine($"Player {TTTCurrentPlayer} wins!\n");
				Console.WriteLine("Play again? (Y/N)");
				string again = Console.ReadLine().ToLower();
				if (again == "y")
				{
					TTTboard = new char[, ]
					{
						{
							'1',
							'2',
							'3'
						},
						{
							'4',
							'5',
							'6'
						},
						{
							'7',
							'8',
							'9'
						}
					};
					TTTCurrentPlayer = 'X';
					moves = 0;
				}
				else
				{
					return;
				}
			}

			if (moves == 9)
			{
				Console.WriteLine("It's a draw!\n");
				Console.WriteLine("Play again? (Y/N)");
				string again = Console.ReadLine().ToLower();
				if (again == "y")
				{
					TTTboard = new char[, ]
					{
						{
							'1',
							'2',
							'3'
						},
						{
							'4',
							'5',
							'6'
						},
						{
							'7',
							'8',
							'9'
						}
					};
					TTTCurrentPlayer = 'X';
					moves = 0;
					return;
				}
				else
				{
					continue;
				}
			}

			if (TTTCurrentPlayer == 'X')
			{
				TTTCurrentPlayer = 'O';
			}
			else
			{
				TTTCurrentPlayer = 'X';
			}
		}
	}

	static void PlayFK()
	{
		bool running = true;
		Console.WriteLine("----- Feeling Lucky! -----");
		while (running)
		{
			Console.WriteLine("\nChoose a game:");
			Console.WriteLine("1. Flip a coin");
			Console.WriteLine("2. Roll a 6-sided die");
			Console.WriteLine("3. Guess a day of the week");
			Console.WriteLine("4. Guess a month");
			Console.WriteLine("5. Roll a 20-sided die");
			Console.WriteLine("6. Guess a card");
			Console.WriteLine("Q. Quit back to main menu");
			Console.Write("Your choice: ");
			string choice = Console.ReadLine().ToLower();
			switch (choice)
			{
				case "1":
					PlayCoinGame();
					break;
				case "2":
					PlayDie6Game();
					break;
				case "3":
					GuessDay();
					break;
				case "4":
					GuessMonth();
					break;
				case "5":
					PlayDie20Game();
					break;
				case "6":
					GuessCard();
					break;
